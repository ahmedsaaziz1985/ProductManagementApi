@ProductManagementApi.API_HostAddress = http://localhost:5204
@token =

### Register
POST {{ProductManagementApi.API_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "Password1",
  "confirmPassword": "Password1"
}

###

### Login
POST {{ProductManagementApi.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "Password1"
}

###

### Get Products (requires JWT)
GET {{ProductManagementApi.API_HostAddress}}/api/products
Authorization: Bearer {{token}}
Accept: application/json

###

POST {{ProductManagementApi.API_HostAddress}}/api/products
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Sample Product",
  "description": "A sample product",
  "price": 29.99,
  "stock": 100,
  "currency": "USD"
}

###

GET {{ProductManagementApi.API_HostAddress}}/api/products/search?search=pen
Authorization: Bearer {{token}}
Accept: application/json

###
